{
    "name": "alperdevv/vending-machine",
    "description": "A vending machine modelled with a pure domain and hexagonal architecture.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.4"
    },
    "autoload": {
        "psr-4": {
            "Vending\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vending\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.65",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.5"
    }
}
